# Auto-detect text files and normalize line endings
* text=auto

# Force LF for common source files
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

# Ignore line endings for binaries
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.mp4     binary
*.mp3     binary
*.zip     binary

# Keep CRLF in .bat files (Windows scripts)
*.bat     text eol=crlf

# Node modules and build output (not tracked)
node_modules/ export-ignore
/build/ export-ignore
/dist/ export-ignore